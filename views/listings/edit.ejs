<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2">
    <h1>You are about to edit</h1>
    <form method="post" action="/listings/<%=listing._id%>?_method=PATCH">
        <div class="mb-3">
            <label for="title" class="form-label">Title:</label>
            <input  type="text" name="listing[title]" value="<%=listing.title%>" class="form-control" ><br>

        </div>
        <div class="mb-3">
            <label class="form-label" for="description">Description:</label>
            <textarea name="listing[description]" class="form-control"><%= listing.description%></textarea><br>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label">Location:</label>
            <input  type="text" name="listing[location]" value="<%=listing.location%>" class="form-control"><br>
        </div>
        <div class="row">
            <div class="mb-3 col-md-8">
                <label for="country" class="form-label">Title:</label>
                <input  type="text" name="listing[country]" value="<%=listing.country%>" class="form-control"><br>
        </div>
        <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price:</label>
            <input  type="number" name="listing[price]" value="<%=listing.price%>" class="form-control"><br>
        </div>

        </div>
        
        <div class="mb-3">
            <label for="image" class="form-label">Image URL:</label>
            <input  type="text" name="listing[image]" value="<%=listing.image%>" class="form-control"><br>
        </div>
        
        
        
        
        
        
        
        <button class="btn add-btn">Submit</button>
    </form>
    </div>
    </div>
    
</body>
