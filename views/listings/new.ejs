<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2">
        
        <h1>Create Listing</h1>
        <form method="post" action="/listings">
            <div class="mb-3">
                <label for="title" class="form-label">Enter Title</label>
                <input  type="text" name="listing[title]" placeholder="enter title" class="form-control"><br>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Enter Description</label>
                <textarea name="listing[description]" placeholder="enter description" class="form-control"></textarea><br>
            </div>
            <div class="mb-3">
                <label for="location" class="form-label">Enter Location</label>
                <input  type="text" name="listing[location]" placeholder="enter location" class="form-control"><br>
            </div>
            <div class="row">
                <div class="mb-3 col-md-8">
                    <label for="country" class="form-label">Enter Country</label>
                    <input  type="text" name="listing[country]" placeholder="enter country" class="form-control"><br>
                </div>

                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Enter Price</label>
                    <input  type="number" name="listing[price]" placeholder="enter price" class="form-control"><br>
                </div>

            </div>
            
            <div class="mb-3">
                <label for="image" class="form-label">Enter Image URL/link</label>
                <input  type="text" name="listing[image]" placeholder="enter image URl/Link" class="form-control"><br>
            </div>
            
            <button class="btn  add-btn">Submit</button>

        </form>
        </div>
    </div>
    
</body>
