<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2">


        
    <h1>Listing Details :</h1>
    </div>

    <div class="card col-6 offset-3 show-card">
        <img src="<%= listing.image%>" class="card-img-top show-img" alt="Default Listing image">
        <div class="card-body">
            <p class="card-text">
                <b><%= listing.title %></b><br>
                <%= listing.description %><br>
                &#8377;<%= listing.price.toLocaleString("en-IN") %><br>
                <%= listing.location %><br>
                <%= listing.country%><br>
            </p>
        </div>
    </div>
    
    <div class="row mt-3">
        <div class="col-6 offset-3 d-flex justify-content-between">
    
    <form method="get" action="/listings/<%= listing._id %>/edit">
      <button class="btn add-btn mb-3">Update</button>
    </form>

    <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-dark mb-3">Delete</button>
    </form>

  </div>
</div>

    

    </div>
    
    
</body>
