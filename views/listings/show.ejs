<% layout("/layouts/boilerplate.ejs") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-3">


        
    <h1><%= listing.title %></h1>
    </div>

    <div class="card col-6 offset-3 show-card listing-card">
        <img src="<%= listing.image%>" class="card-img-top show-img" alt="Default Listing image">
        <div class="card-body">
            <p class="card-text">
                
                <%= listing.description %><br>
                &#8377;<%= listing.price.toLocaleString("en-IN") %><br>
                <%= listing.location %><br>
                <%= listing.country%><br>
            </p>
        </div>
    </div>
    
    <div class="row mt-3">
        <div class="col-6 offset-3 d-flex justify-content-between">
    
    <form method="get" action="/listings/<%= listing._id %>/edit">
      <button class="btn add-btn mb-3">Update</button>
    </form>

    <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-dark mb-3">Delete</button>
    </form>

  </div>
  <!-- Creating review form -->
  <div class="col-8 offset-3">
    <hr>
    <h4>Leave a review</h4>
    <form method="post" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">
        <div class="mb-3 mt-3">
            <label for="rating" class="form label">Rating</label>
            <input class="form-range" type="range" min="1" max="5" name="review[rating]" id="rating" >
            
        </div>
        <div class="mb-3 mt-3">
            <label for="comment" class="form label">Comment</label><br>
            <textarea name="review[comment]" class="form-control" id="comment" rows="10" cols="50" required></textarea>
            <div class="invalid-feedback">Please give required feedback</div>
        </div>
        <button class="btn btn-dark mt-2 mb-3">Submit</button>
    </form>
    <hr>
    <h4>All Reviews:</h4>
    <div class="row">
        <% for(let review of listing.reviews){ %>
        <div class="card col-5 ms-2 mt-3 mb-3">
            <div class="card-body">
                <p class="card-text"><%= review.comment%></p>
                <p class="card-text"><%= review.rating%> stars</p>
            </div>
            <form method="post" class="mb-3" action="/listings/<%= listing._id%>/reviews/<%= review._id %>?_method=DELETE"><button class="btn btn-sm btn-dark">Delete</button></form>
            
        </div>
   <% } %>

    </div>
    
    
  </div>
</div>

    

    </div>
    
    
</body>
